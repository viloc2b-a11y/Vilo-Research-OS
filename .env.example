# Supabase project: "Vilo Research OS" (staging)
# Dashboard: https://supabase.com/dashboard → Vilo Research OS → Settings → API

# Browser-safe (Cloudflare Pages / local)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon...

# Server-only — never NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJ...service...role...

# One-time internal bootstrap (npm run db:bootstrap-org-owner) — service role only
# BOOTSTRAP_ORG_OWNER_EMAIL=jmendez@viloresearchgroup.com
# BOOTSTRAP_ORG_ID=
# BOOTSTRAP_ORG_NAME=

# Postgres for npm run db:migrate (postgres.js)
# Prefer DIRECT URI for DDL (avoids pooler "Tenant or user not found" issues):
# DATABASE_URL_DIRECT=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
#
# Transaction pooler (6543): username must be postgres.[PROJECT_REF]; URL-encode password.
# Migrate script sets prepare:false for *.pooler.supabase.com — required for postgres.js + PgBouncer.

DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# VPI feature flags (lib/performance/read-layer)
# When true, /performance uses vpi_load_dashboard RPC with automatic signal fallback.
VPI_USE_RPC=true
# Scoring lite (Phase 7C). Set false only for rollback; default is on when unset.
VPI_SCORING_ENABLED=true

# OpenRouter server-side API access.
# Server-only. Do not expose this value to browser/client bundles.
OPENROUTER_API_KEY=your_server_side_openrouter_key
