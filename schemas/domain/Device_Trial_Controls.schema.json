{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vilo.os/schemas/domain/Device_Trial_Controls/1.0.0",
  "title": "Device Trial Controls Row",
  "description": "Device accountability, calibration, malfunction workflows.",
  "type": "object",
  "additionalProperties": false,
  "x-vilo-schema-version": "1.0.0",
  "properties": {
    "module_row_id": {
      "$ref": "../common/common.schema.json#/$defs/ModuleRowID"
    },
    "study_template_id": {
      "$ref": "../common/common.schema.json#/$defs/StudyTemplateID"
    },
    "module_id": {
      "type": "string",
      "const": "MOD-device_trials"
    },
    "compatible_core_schema_version": {
      "$ref": "../common/common.schema.json#/$defs/SemverRange"
    },
    "module_schema_version": {
      "$ref": "../common/common.schema.json#/$defs/SemverVersion"
    },
    "visit_id": {
      "$ref": "../common/common.schema.json#/$defs/VisitID"
    },
    "procedure_id": {
      "$ref": "../common/common.schema.json#/$defs/ProcedureID"
    },
    "active_flag": {
      "$ref": "../common/common.schema.json#/$defs/BooleanFlag"
    },
    "device_module_id": {
      "type": "string",
      "pattern": "^DEV-[0-9]{3}$"
    },
    "device_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "serial_number": {
      "type": "string",
      "maxLength": 128
    },
    "implant_use_date": {
      "$ref": "../common/common.schema.json#/$defs/ISODate"
    },
    "calibration_required": {
      "$ref": "../common/common.schema.json#/$defs/BooleanFlag"
    },
    "software_version": {
      "type": "string",
      "maxLength": 64
    },
    "wear_time_required": {
      "$ref": "../common/common.schema.json#/$defs/BooleanFlag"
    },
    "malfunction_flag": {
      "$ref": "../common/common.schema.json#/$defs/BooleanFlag"
    },
    "retrieval_required": {
      "$ref": "../common/common.schema.json#/$defs/BooleanFlag"
    },
    "accountability_status": {
      "$ref": "../common/common.schema.json#/$defs/ControlledValueCode"
    },
    "x_vilo_provenance": {
      "$ref": "../common/common.schema.json#/$defs/ProvenanceReference",
      "description": "Optional provenance when row is AI- or parser-filled."
    }
  },
  "required": [
    "module_row_id",
    "study_template_id",
    "module_id",
    "compatible_core_schema_version",
    "module_schema_version",
    "active_flag",
    "device_module_id",
    "device_id"
  ]
}
