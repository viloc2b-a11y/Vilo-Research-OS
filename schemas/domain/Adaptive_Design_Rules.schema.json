{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vilo.os/schemas/domain/Adaptive_Design_Rules/1.0.0",
  "title": "Adaptive Design Rule Row",
  "description": "Adaptive/interim design triggers and committee decisions.",
  "type": "object",
  "additionalProperties": false,
  "x-vilo-schema-version": "1.0.0",
  "properties": {
    "module_row_id": {
      "$ref": "../common/common.schema.json#/$defs/ModuleRowID"
    },
    "study_template_id": {
      "$ref": "../common/common.schema.json#/$defs/StudyTemplateID"
    },
    "module_id": {
      "type": "string",
      "const": "MOD-adaptive_design"
    },
    "compatible_core_schema_version": {
      "$ref": "../common/common.schema.json#/$defs/SemverRange"
    },
    "module_schema_version": {
      "$ref": "../common/common.schema.json#/$defs/SemverVersion"
    },
    "visit_id": {
      "$ref": "../common/common.schema.json#/$defs/VisitID"
    },
    "procedure_id": {
      "$ref": "../common/common.schema.json#/$defs/ProcedureID"
    },
    "active_flag": {
      "$ref": "../common/common.schema.json#/$defs/BooleanFlag"
    },
    "adaptive_rule_id": {
      "$ref": "../common/common.schema.json#/$defs/RuleID"
    },
    "trigger_type": {
      "$ref": "../common/common.schema.json#/$defs/ControlledValueCode"
    },
    "interim_timepoint": {
      "$ref": "../common/common.schema.json#/$defs/ISODate"
    },
    "analysis_committee": {
      "$ref": "../common/common.schema.json#/$defs/RoleName"
    },
    "decision_type": {
      "$ref": "../common/common.schema.json#/$defs/ControlledValueCode"
    },
    "modification_action": {
      "$ref": "../common/common.schema.json#/$defs/ControlledValueCode"
    },
    "reestimate_sample_size": {
      "$ref": "../common/common.schema.json#/$defs/BooleanFlag"
    },
    "drop_arm_flag": {
      "$ref": "../common/common.schema.json#/$defs/BooleanFlag"
    },
    "enrichment_flag": {
      "$ref": "../common/common.schema.json#/$defs/BooleanFlag"
    },
    "version_control_required": {
      "$ref": "../common/common.schema.json#/$defs/BooleanFlag"
    },
    "x_vilo_provenance": {
      "$ref": "../common/common.schema.json#/$defs/ProvenanceReference",
      "description": "Optional provenance when row is AI- or parser-filled."
    }
  },
  "required": [
    "module_row_id",
    "study_template_id",
    "module_id",
    "compatible_core_schema_version",
    "module_schema_version",
    "active_flag",
    "adaptive_rule_id",
    "trigger_type",
    "decision_type",
    "modification_action"
  ]
}
