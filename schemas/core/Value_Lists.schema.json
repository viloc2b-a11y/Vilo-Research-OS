{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vilo.os/schemas/core/Value_Lists/1.0.0",
  "title": "Value List Row",
  "description": "Controlled vocabulary item.",
  "type": "object",
  "additionalProperties": false,
  "x-vilo-schema-version": "1.0.0",
  "properties": {
    "study_template_id": {
      "$ref": "../common/common.schema.json#/$defs/StudyTemplateID"
    },
    "list_code": {
      "$ref": "../common/common.schema.json#/$defs/ControlledListName"
    },
    "item_code": {
      "$ref": "../common/common.schema.json#/$defs/ControlledValueCode"
    },
    "item_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "sort_order": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9999
    },
    "active_flag": {
      "$ref": "../common/common.schema.json#/$defs/BooleanFlag"
    },
    "x_vilo_provenance": {
      "$ref": "../common/common.schema.json#/$defs/ProvenanceReference",
      "description": "Optional provenance when row is AI- or parser-filled."
    }
  },
  "required": [
    "study_template_id",
    "list_code",
    "item_code",
    "item_label",
    "active_flag"
  ]
}
