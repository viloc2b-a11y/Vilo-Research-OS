    { "section": "Consent", "field_name": "consent_date", "required": true, "data_type_label": "Date", "example": "2026-05-16", "notes": "Fecha de firma/obtención." },
    { "section": "Consent", "field_name": "consent_verified_by", "required": true, "data_type_label": "Text", "example": "J. Smith", "notes": "Iniciales o nombre del staff." },
    { "section": "Consent", "field_name": "reconsent_required", "required": false, "data_type_label": "Yes/No", "example": "No", "notes": "Marcar si aplica." },
    { "section": "Specimen", "field_name": "specimen_type", "required": true, "data_type_label": "List", "example": "Whole Blood", "notes": "Sangre, plasma, saliva, etc." },
