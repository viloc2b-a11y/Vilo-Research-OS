{
  "template_id": "biospecimen-canonical-v1",
  "description": "Canonical biospecimen collection-only source document baseline (Source_Template, Value_Lists, Instructions).",
  "source_template": [
    { "section": "Header", "field_name": "study_protocol", "required": true, "data_type_label": "Text", "example": "BIO-101", "notes": "Protocolo o estudio." },
    { "section": "Header", "field_name": "protocol_version", "required": true, "data_type_label": "Text", "example": "v1.0", "notes": "Versión vigente." },
    { "section": "Header", "field_name": "site_name", "required": true, "data_type_label": "Text", "example": "Site A", "notes": "Sitio de colección." },
    { "section": "Header", "field_name": "subject_id", "required": true, "data_type_label": "Text", "example": "1007", "notes": "Identificador del sujeto." },
    { "section": "Header", "field_name": "collection_event", "required": true, "data_type_label": "Text", "example": "Baseline", "notes": "Visita o evento de recolección." },
    { "section": "Header", "field_name": "collection_date", "required": true, "data_type_label": "Date", "example": "2026-05-16", "notes": "Fecha de colección." },
    { "section": "Header", "field_name": "collection_time", "required": true, "data_type_label": "Time", "example": "08:15", "notes": "Hora de colección." },
