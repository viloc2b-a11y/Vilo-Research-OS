    { "section": "Shipping", "field_name": "ship_condition", "required": false, "data_type_label": "List", "example": "Frozen", "notes": "Refrigerado, frozen, ambient." },
    { "section": "Quality", "field_name": "sample_acceptable", "required": true, "data_type_label": "Yes/No", "example": "Yes", "notes": "Muestra válida." },
    { "section": "Quality", "field_name": "deviation_flag", "required": true, "data_type_label": "Yes/No", "example": "No", "notes": "Si hubo desviación." },
    { "section": "Quality", "field_name": "deviation_description", "required": false, "data_type_label": "Text", "example": "Delay in processing", "notes": "Descripción de la desviación." },
    { "section": "Quality", "field_name": "sample_rejected", "required": true, "data_type_label": "Yes/No", "example": "No", "notes": "Si la muestra fue rechazada." },
    { "section": "Quality", "field_name": "rejection_reason", "required": false, "data_type_label": "Text", "example": "Low volume", "notes": "Motivo si aplica." },
    { "section": "Closeout", "field_name": "source_complete", "required": true, "data_type_label": "Yes/No", "example": "Yes", "notes": "Indica cierre documental." },
    { "section": "Closeout", "field_name": "reviewed_by", "required": true, "data_type_label": "Text", "example": "PI 1", "notes": "Revisor final." },
    { "section": "Closeout", "field_name": "reviewed_date", "required": true, "data_type_label": "Date", "example": "2026-05-16", "notes": "Fecha de revisión." },
    { "section": "Closeout", "field_name": "comments", "required": false, "data_type_label": "Text", "example": "No issues noted", "notes": "Observaciones finales." }
