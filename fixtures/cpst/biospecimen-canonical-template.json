  "instructions": [
    { "topic": "Purpose", "instruction": "This template captures source data for biospecimen collection only." },
    { "topic": "Use", "instruction": "The source document should be completed at the time of collection or as soon as possible after collection." },
    { "topic": "Consent", "instruction": "Do not collect any specimen before informed consent is verified." },
    { "topic": "Subject ID", "instruction": "Use the protocol-approved subject identifier only." },
    { "topic": "Specimen Label", "instruction": "Every specimen must have a unique label ID." },
    { "topic": "Processing", "instruction": "If processing is performed, document date, time, and staff." },
    { "topic": "Storage", "instruction": "Document final storage location exactly as assigned." },
    { "topic": "Shipping", "instruction": "If shipped, document destination, courier, and tracking number." },
    { "topic": "Quality", "instruction": "Record deviations, rejection reasons, or acceptability clearly." },
    { "topic": "Closeout", "instruction": "Mark source complete only after review by the appropriate staff." },
    { "topic": "Data Entry", "instruction": "Use only the allowed values from Value_Lists." },
    { "topic": "Missing Data", "instruction": "Leave blank if not applicable; do not enter zeros unless the value is truly zero." }
  ],
  "section_to_procedure_code": {
    "Header": "BIO_HEADER",
    "Consent": "BIO_CONSENT",
    "Specimen": "BIO_SPECIMEN",
    "Processing": "BIO_PROCESS",
