    { "section": "Specimen", "field_name": "quantity_unit", "required": true, "data_type_label": "List", "example": "mL", "notes": "Unidades estandarizadas." },
    { "section": "Specimen", "field_name": "collection_method", "required": true, "data_type_label": "Text", "example": "Venipuncture", "notes": "Método usado." },
    { "section": "Specimen", "field_name": "collection_performed_by", "required": true, "data_type_label": "Text", "example": "CRC 1", "notes": "Persona que recolectó." },
    { "section": "Specimen", "field_name": "collection_condition", "required": false, "data_type_label": "List", "example": "Normal", "notes": "Normal, hemolyzed, insufficient, etc." },
    { "section": "Processing", "field_name": "processed", "required": true, "data_type_label": "Yes/No", "example": "Yes", "notes": "Si hubo procesamiento." },
    { "section": "Processing", "field_name": "processing_date", "required": false, "data_type_label": "Date", "example": "2026-05-16", "notes": "Fecha de procesamiento." },
    { "section": "Processing", "field_name": "processing_time", "required": false, "data_type_label": "Time", "example": "08:40", "notes": "Hora de procesamiento." },
    { "section": "Processing", "field_name": "processed_by", "required": false, "data_type_label": "Text", "example": "Lab Tech 1", "notes": "Quien procesó." },
    { "section": "Processing", "field_name": "processing_method", "required": false, "data_type_label": "Text", "example": "Centrifuged", "notes": "Método de procesamiento." },
    { "section": "Processing", "field_name": "aliquoted", "required": false, "data_type_label": "Yes/No", "example": "Yes", "notes": "Si se hicieron alícuotas." },
