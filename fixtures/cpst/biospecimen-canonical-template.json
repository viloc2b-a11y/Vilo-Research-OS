    { "section": "Storage", "field_name": "rack_box_position", "required": false, "data_type_label": "Text", "example": "Rack B / Box 4", "notes": "Posición exacta." },
    { "section": "Storage", "field_name": "stored_by", "required": false, "data_type_label": "Text", "example": "Lab Tech 1", "notes": "Persona que almacenó." },
    { "section": "Storage", "field_name": "storage_date", "required": true, "data_type_label": "Date", "example": "2026-05-16", "notes": "Fecha de almacenamiento." },
    { "section": "Shipping", "field_name": "ship_required", "required": true, "data_type_label": "Yes/No", "example": "No", "notes": "Si se enviará al biorepositorio." },
